# Pipeline
PIPELINE_ENV=development
DATA_DIR=./data
LOG_LEVEL=INFO
MAX_WORKERS=16
BATCH_SIZE=1000

# Supervisor (run-until-goal mode)
TARGET_COUNT=6000000
CHECKPOINT_INTERVAL_SEC=30
STALL_TIMEOUT_SEC=900
REFILL_URL_QUEUE_THRESHOLD=50000

# Download
DOWNLOAD_TIMEOUT_SEC=60
DOWNLOAD_RETRIES=3
RATE_LIMIT_PER_DOMAIN=2  # requests per second

# Quality thresholds (override config/quality_thresholds.yaml)
MIN_QUALITY_SCORE=60
MIN_SLIDE_COUNT=5
MAX_FILE_SIZE_MB=200

# Storage — qualified files in PostgreSQL when DATABASE_URL is set
STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://pipeline:password@localhost:5432/pipeline

# AI / Vision (optional — for quality scoring)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VISION_MODEL=gpt-4o

# Cloud delivery (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PREFIX=presentation-dataset/

# Redis (optional — for distributed queue)
REDIS_URL=redis://localhost:6379/0
